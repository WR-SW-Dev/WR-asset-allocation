# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# venv
.venv
.venv/
venv/

# Environment
.env

# Data — gitignored except fixtures and .gitkeep
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/external/*
!data/external/.gitkeep

# Morningstar Direct — LICENSED vendor data. Never commit raw exports or any
# series/reports derived from them. Only code, schemas, configs, docs, tiny
# synthetic fixtures, and tests are committed (see docs/morningstar_index_returns_spec.md).
data/vendor/
!data/vendor/morningstar/raw/.gitkeep
data/normalized/*
!data/normalized/.gitkeep
reports/morningstar_*
# Morningstar credentials / local overrides (if a live path is ever added).
configs/morningstar_credentials_local.yaml
.env.morningstar

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Phase 14 — workbook ingestion local override.
# The committed configs/workbook_v7_manifest.yaml is a SCAFFOLD with
# `<TODO_*>` placeholder sheet names. The user copies it to the
# `_local.yaml` variant, fills in real sheet names + row classification
# rules, and runs ingestion against the local file. The local variant
# is gitignored so live sheet identifiers and per-row classification
# detail never reach the repo.
configs/workbook_v7_manifest_local.yaml
configs/investment_summary_manifest_local.yaml
# Phase 20 / L20 — local study config overlay (live workbook paths + ingestion wiring).
# DO NOT COMMIT — carries live sheet names and Windows file paths.
configs/base_local.yaml
